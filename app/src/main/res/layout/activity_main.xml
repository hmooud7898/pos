<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#0f3460"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="POS" android:textColor="#ffffff"
            android:textSize="16sp" android:textStyle="bold" android:paddingEnd="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TABLE:" android:textColor="#cccccc" android:textSize="10sp"/>
        <EditText android:id="@+id/et_table" android:layout_width="60dp" android:layout_height="38dp"
            android:hint="201" android:inputType="number" android:textColor="#ffffff"
            android:textColorHint="#888888" android:background="#16213e"
            android:textSize="16sp" android:textStyle="bold" android:gravity="center"
            android:padding="4dp" android:imeOptions="actionDone" android:singleLine="true"/>
        <Button android:id="@+id/btn_go" android:layout_width="46dp" android:layout_height="36dp"
            android:text="GO" android:textColor="#ffffff" android:backgroundTint="#2980b9"
            android:textSize="11sp" android:layout_marginStart="3dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SRV:" android:textColor="#cccccc" android:textSize="10sp"
            android:layout_marginStart="4dp"/>
        <EditText android:id="@+id/et_server" android:layout_width="0dp" android:layout_height="38dp"
            android:layout_weight="1" android:textColor="#ffffff" android:background="#16213e"
            android:textSize="12sp" android:padding="4dp" android:singleLine="true"/>
        <Button android:id="@+id/btn_settings" android:layout_width="42dp" android:layout_height="36dp"
            android:text="S" android:textColor="#ffffff" android:backgroundTint="#555555"
            android:textSize="13sp" android:layout_marginStart="2dp"/>
        <Button android:id="@+id/btn_tables" android:layout_width="42dp" android:layout_height="36dp"
            android:text="T" android:textColor="#ffffff" android:backgroundTint="#e67e22"
            android:textSize="13sp" android:layout_marginStart="2dp"/>
        <Button android:id="@+id/btn_reports" android:layout_width="42dp" android:layout_height="36dp"
            android:text="R" android:textColor="#ffffff" android:backgroundTint="#16a085"
            android:textSize="13sp" android:layout_marginStart="2dp"/>
    </LinearLayout>

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="58dp"
        android:background="#0a0a1a" android:fillViewport="false">
        <LinearLayout android:id="@+id/tables_bar" android:layout_width="wrap_content"
            android:layout_height="match_parent" android:orientation="horizontal" android:padding="4dp"/>
    </HorizontalScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:background="#16213e">

            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="48dp">
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/category_tabs"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="#0f3460"
                    app:tabTextColor="#aaaaaa"
                    app:tabSelectedTextColor="#ffffff"
                    app:tabIndicatorColor="#e94560"
                    app:tabMode="scrollable"/>
            </HorizontalScrollView>

            <GridView android:id="@+id/dish_grid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:numColumns="3"
                android:verticalSpacing="4dp"
                android:horizontalSpacing="4dp"
                android:padding="4dp"
                android:stretchMode="columnWidth"/>
        </LinearLayout>

        <LinearLayout android:layout_width="280dp" android:layout_height="match_parent"
            android:orientation="vertical" android:background="#1a1a2e" android:padding="6dp">
            <TextView android:id="@+id/tv_table_info" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="No table selected"
                android:textColor="#4fc3f7" android:textSize="13sp" android:textStyle="bold"
                android:gravity="center" android:paddingBottom="4dp"/>
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout android:id="@+id/order_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"/>
            </ScrollView>
            <TextView android:id="@+id/tv_total" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="LL: 0"
                android:textColor="#f1c40f" android:textSize="13sp" android:textStyle="bold"
                android:gravity="center" android:paddingTop="4dp" android:paddingBottom="4dp"/>
            <Button android:id="@+id/btn_kitchen" android:layout_width="match_parent"
                android:layout_height="50dp" android:text="KITCHEN"
                android:textColor="#ffffff" android:backgroundTint="#27ae60"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <Button android:id="@+id/btn_bill" android:layout_width="match_parent"
                android:layout_height="50dp" android:text="BILL"
                android:textColor="#ffffff" android:backgroundTint="#e67e22"
                android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <Button android:id="@+id/btn_clear" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="CLEAR PENDING"
                android:textColor="#ffffff" android:backgroundTint="#c0392b"
                android:textSize="12sp" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Tap=remove | Long hold BILL=direct print"
                android:textColor="#555555" android:textSize="9sp" android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
